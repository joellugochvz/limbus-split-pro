<Window x:Class="LimbusSplitPro.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Limbus Split Pro"
        MinWidth="960" MinHeight="600"
        FontFamily="{StaticResource AppFontFamily}">
    <!--
      Andamiaje mínimo. La composición final de panel izquierdo/derecho (sección 18)
      se implementa junto con el mockup visual pendiente de aprobación, para no fijar
      un layout definitivo antes de acordar la identidad visual.
    -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Panel izquierdo: mezcla, qué extraer, carpeta" Margin="16" TextWrapping="Wrap" />
        <TextBlock Grid.Column="1" Text="Panel derecho: resultado, reproductor, mezclador" Margin="16" TextWrapping="Wrap" />
    </Grid>
</Window>
